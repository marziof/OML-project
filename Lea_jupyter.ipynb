    "# ── Plain Gradient Descent ────────────────────────────────────────────────────\n",
    "def plain_gd(grad, eta=0.01, num_epochs=300):\n",
    "    x = np.array([-0.5, 1.5])\n",
    "    trajectory = [x.copy()]\n",
    "    for _ in range(num_epochs):\n",
    "        x = x - eta * grad(x)\n",
    "        trajectory.append(x.copy())\n",
    "    return x, trajectory"
