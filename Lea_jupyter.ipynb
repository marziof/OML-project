    "def ackley_fn(theta):\n",
    "    x, y = theta\n",
    "    return (-20 * np.exp(-0.2 * np.sqrt(0.5*(x**2 + y**2)))\n",
    "            - np.exp(0.5*(np.cos(2*np.pi*x) + np.cos(2*np.pi*y)))\n",
    "            + np.e + 20)\n",
    "\n",
    "def ackley_gd(theta):\n",
    "    x, y = theta\n",
    "    r = np.sqrt(0.5*(x**2 + y**2))\n",
    "    exp1 = np.exp(-0.2 * r)\n",
    "    exp2 = np.exp(0.5*(np.cos(2*np.pi*x) + np.cos(2*np.pi*y)))\n",
